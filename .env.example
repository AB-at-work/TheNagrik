# ─────────────────────────────────────────────────────────────
# The Nagrik — Environment Variables (copy to .env and fill in)
# ─────────────────────────────────────────────────────────────

# ── Database ──
DATABASE_URL=postgresql://nagrik:nagrik@localhost:5432/thenagrik_dev

# ── Auth ──
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-secure-256-bit-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12

# ── Seed admin (used only by db:seed) ──
SEED_ADMIN_EMAIL=admin@thenagrik.org
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Super Admin

# ── Email (Resend) ──
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=The Nagrik <noreply@thenagrik.org>
ADMIN_EMAIL=thenagrik.org@gmail.com

# ── Storage (Cloudflare R2) ──
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=thenagrik-media
R2_PUBLIC_URL=https://media.thenagrik.org

# ── CAPTCHA (Cloudflare Turnstile) ──
TURNSTILE_SECRET_KEY=your_turnstile_secret
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key

# ── Application ──
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── ISR revalidation (backend -> frontend webhook) ──
REVALIDATION_SECRET=replace-with-a-shared-secret

# ── Analytics ──
NEXT_PUBLIC_GA_ID=
